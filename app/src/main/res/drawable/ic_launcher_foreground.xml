<?xml version="1.0" encoding="utf-8"?>
<!-- Compass rose fused with an audio "play" hub: an eight-point star whose centre is a
     play triangle, so the mark reads as both a compass (voyage) and audio playback. Centred
     in the 66dp safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Diagonal points (NE/SE/SW/NW), cream -->
    <path
        android:fillColor="#FFF3E7C9"
        android:pathData="M69.56,38.44 L62,54 L69.56,69.56 L54,62 L38.44,69.56 L46,54 L38.44,38.44 L54,46 Z" />
    <!-- Cardinal points (N/E/S/W), gold -->
    <path
        android:fillColor="#FFE8B23C"
        android:pathData="M54,21 L59.66,48.34 L87,54 L59.66,59.66 L54,87 L48.34,59.66 L21,54 L48.34,48.34 Z" />
    <!-- Hub: navy disc -->
    <path
        android:fillColor="#FF0D1A33"
        android:pathData="M54,42 a12,12 0 1,0 0.1,0 Z" />
    <!-- Play triangle in the hub (audio cue), gold -->
    <path
        android:fillColor="#FFE8B23C"
        android:pathData="M50,47.5 L50,60.5 L61.5,54 Z" />
</vector>
