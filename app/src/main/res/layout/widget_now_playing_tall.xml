<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="14dp"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/iv_cover_art"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:scaleType="fitXY"
            android:contentDescription="@string/cover_art" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/widget_no_book"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFA552" />

        <TextView
            android:id="@+id/tv_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#B6AB9C" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:id="@+id/btn_skip_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/skip_back" />

            <ImageView
                android:id="@+id/btn_play_pause"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/play_pause" />

            <ImageView
                android:id="@+id/btn_skip_forward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/skip_forward" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
