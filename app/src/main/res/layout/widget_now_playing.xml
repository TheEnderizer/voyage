<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dynamic, accent-tinted rounded card background (rendered in code) -->
    <ImageView
        android:id="@+id/iv_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:clipToPadding="false">

        <!-- Left: note badge + text + controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_note"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginBottom="6dp"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_no_book"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFA552" />

            <TextView
                android:id="@+id/tv_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#B6AB9C"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <ImageView
                    android:id="@+id/btn_skip_back"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:contentDescription="@string/skip_back" />

                <ImageView
                    android:id="@+id/btn_play_pause"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@string/play_pause" />

                <ImageView
                    android:id="@+id/btn_skip_forward"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:contentDescription="@string/skip_forward" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right: cover art -->
        <ImageView
            android:id="@+id/iv_cover_art"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginStart="12dp"
            android:scaleType="fitXY"
            android:contentDescription="@string/cover_art" />

    </LinearLayout>

</FrameLayout>
